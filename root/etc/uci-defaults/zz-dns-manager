#!/bin/sh

. /lib/functions.sh

# Configure dnscrypt-proxy2
DC_CONF="/etc/dnscrypt-proxy2/dnscrypt-proxy.toml"
if [ -f "$DC_CONF" ]; then
    sed -i "s/^listen_addresses = .*/listen_addresses = ['127.0.0.1:9053']/" "$DC_CONF"
    sed -i 's/^# server_names.*/server_names = ["nextdns-ultralow", "nextdns", "dns.sb", "adguard-dns-unfiltered-doh", "cloudflare", "controld-unfiltered", "controld-uncensored", "rethinkdns-doh", "mullvad-doh", "wikimedia", "quad9-doh-ip4-port443-nofilter-pri", "quad9-doh-ip4-port443-nofilter-ecs-pri", "dnscry.pt-taipeh-ipv4", "dnscry.pt-manila-ipv4", "jp.tiar.app-doh", "cs-singapore", "cs-tokyo"]/' "$DC_CONF"
    sed -i 's/^# lb_strategy.*/lb_strategy = "p5"/' "$DC_CONF"
    sed -i 's/^cache_size = 4096/cache_size = 16384/' "$DC_CONF"
    sed -i 's|^# forwarding_rules.*|forwarding_rules = "/etc/dnscrypt-proxy2/forwarding-rules.txt"|' "$DC_CONF"
    sed -i 's/^bootstrap_resolvers.*/bootstrap_resolvers = ["223.5.5.5:53", "119.29.29.29:53"]/' "$DC_CONF"
    sed -i 's/^ignore_system_dns.*/ignore_system_dns = true/' "$DC_CONF"
fi

# Generate forwarding-rules.txt from bundled chinalist
RULES="/etc/dnscrypt-proxy2/forwarding-rules.txt"
CHINALIST="/etc/dns-manager/chinalist.txt"
CUSTOM="/etc/dns-manager/custom-chinalist.txt"
config_load dns-manager
config_get CHINA_DNS main china_dns "223.5.5.5:53, 119.29.29.29:53"
config_get DEFAULT_CUSTOM main custom_domains ""
if [ ! -f "$RULES" ] && [ -f "$CHINALIST" ]; then
    mkdir -p /etc/dnscrypt-proxy2
    if [ ! -f "$CUSTOM" ] && [ -n "$DEFAULT_CUSTOM" ]; then
        echo "$DEFAULT_CUSTOM" | tr ' ' '\n' > "$CUSTOM"
    fi
    {
        cat "$CHINALIST"
        [ -f "$CUSTOM" ] && cat "$CUSTOM"
    } | sort -u | awk -v dns="$CHINA_DNS" 'NF {print $0 "  " dns}' > "$RULES"
fi

# Configure AdGuardHome via API (generates a valid config for the installed version)
AGH_CONF="/etc/adguardhome.yaml"
if [ ! -f "$AGH_CONF" ] || ! grep -q "127.0.0.1:9053" "$AGH_CONF" 2>/dev/null; then
    mkdir -p /tmp/agh-setup/data
    AGH_SETUP_PORT=39482
    /usr/bin/AdGuardHome -c /tmp/agh-setup/AdGuardHome.yaml -w /tmp/agh-setup --web-addr 127.0.0.1:$AGH_SETUP_PORT &
    AGH_PID=$!

    agh_ready=0
    for i in $(seq 1 20); do
        curl -s -o /dev/null "http://127.0.0.1:$AGH_SETUP_PORT/" && agh_ready=1 && break
        sleep 0.5
    done

    if [ "$agh_ready" = "1" ]; then
        HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" -X POST "http://127.0.0.1:$AGH_SETUP_PORT/control/install/configure" \
            -H "Content-Type: application/json" \
            -d '{"web":{"ip":"0.0.0.0","port":3000},"dns":{"ip":"0.0.0.0","port":53},"username":"admin","password":"admin123"}')
    else
        HTTP_CODE="000"
    fi

    kill $AGH_PID 2>/dev/null
    wait $AGH_PID 2>/dev/null
    sleep 1

    if [ "$HTTP_CODE" = "200" ] && [ -f /tmp/agh-setup/AdGuardHome.yaml ]; then
        cp /tmp/agh-setup/AdGuardHome.yaml "$AGH_CONF"
        sed -i 's|https://dns10.quad9.net/dns-query|127.0.0.1:9053|' "$AGH_CONF"
        sed -i 's/^    - 9\.9\.9\.10/    - 223.5.5.5/' "$AGH_CONF"
        sed -i 's/^    - 149\.112\.112\.10/    - 119.29.29.29/' "$AGH_CONF"
        sed -i '/    - 2620:fe::10/d; /    - 2620:fe::fe:10/d' "$AGH_CONF"
        sed -i 's/^  cache_size: 4194304/  cache_size: 33554432/' "$AGH_CONF"
        sed -i 's/^  cache_ttl_min: 0/  cache_ttl_min: 600/' "$AGH_CONF"
        sed -i 's/^  cache_ttl_max: 0/  cache_ttl_max: 86400/' "$AGH_CONF"
        sed -i 's/^  cache_optimistic: false/  cache_optimistic: true/' "$AGH_CONF"
        sed -i 's/^  aaaa_disabled: false/  aaaa_disabled: true/' "$AGH_CONF"
        sed -i 's/^  ratelimit: 20/  ratelimit: 2000/' "$AGH_CONF"
    elif [ -f /etc/dns-manager/adguardhome.yaml.template ]; then
        cp /etc/dns-manager/adguardhome.yaml.template "$AGH_CONF"
    fi
    rm -rf /tmp/agh-setup
fi

# Free port 53 for AdGuardHome: move dnsmasq to port 54
if ! uci -q get dhcp.@dnsmasq[0].port >/dev/null; then
    uci set dhcp.@dnsmasq[0].port=54
    uci commit dhcp
    /etc/init.d/dnsmasq restart
fi

# Seed default warmup domains
WARMUP_DIR="/etc/dns-warmup"
if [ ! -f "$WARMUP_DIR/top-domains.txt" ] && [ -f "$WARMUP_DIR/top-domains.default" ]; then
    mkdir -p "$WARMUP_DIR"
    cp "$WARMUP_DIR/top-domains.default" "$WARMUP_DIR/top-domains.txt"
fi

# Schedule daily warmup domain list refresh (4:00 AM)
( crontab -l 2>/dev/null | grep -v 'dns-extract-top'; echo '0 4 * * * /usr/bin/dns-extract-top.sh 300 >/dev/null 2>&1' ) | crontab -

exit 0
